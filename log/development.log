<p style="color: green"><%= notice %></p>
<header class="d-flex justify-content-center align-items-start">
    <div>
      <%= render @post %>
    </div>

    <div class="card m-3 p-3 card_">
      <div class="container">
        <%= render 'comments/form', post: @post %>
      </div>

      <div>
        <% @comments.each do |comment| %>

            <% if comment.post.id == @post.id %>
              <div class="d-flex align-items-start container_theme">
                <%= image_tag("user.png", class:"user_comment_png")%>
                <div>
                <p class="comment_email">
                  <%= comment.user.email %> <br>
                  <p class="comment_content"><%= comment.content %></p>
                </p></div>
              </div>
            <% end %>

        <% end %>
      </div>
      <div> 
      <% if current_user.id == @post.user_id %>
          <%= link_to "Edit this post", edit_post_path(@post) %><i class="fa-solid fa-pen-to-square m-1"></i> |
          <%= link_to "Back to posts", posts_path %><i class="fa-solid fa-arrow-right-from-bracket m-1"></i>
          <%= button_to "Destroy this post", @post, class:"btn btn-primary" method: :delete %>
      <% else %>
          <div class="back">
            <%= link_to "Back to posts", posts_path %> <i class="fa-solid fa-arrow-right-from-bracket m-1"></i>
          </div>
      <% end %>
  </div>
    </div>
</header>
</body>
