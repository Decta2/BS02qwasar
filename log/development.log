36:            <li class="nav-item m-3">
37:              <%= link_to "Dashboard", projects_path, class:"navbar_item"%>
38:            </li>
39:            <li class="nav-item d-flex align-items-center m-3">
40:                  <%= link_to "New project", new_project_path, class:"navbar_item"%>
41:            </li>
42:            <li class="nav-item d-flex align-items-center m-3">
43:                  <%= link_to "Posts", posts_path, class:"navbar_item"%>
44:            </li>
45:    
46:            <li class="nav-item d-flex align-items-center m-3">
47:                  <% link_to "Log out", destroy_user_session_path, method: :delete, class:"nav_item" %>
48:            </li>
49:            <li class="nav-item d-flex align-items-center m-3">
50:            </li>
51:          </ul>
52:          <!-- Left links -->
53:    
54:          <div class="d-flex align-items-center">
55:             
56:                  <%= button_to 'log out', destroy_user_session_path, method: :delete, class:"button m-2 " %>
57:            
58:            
59:            <a
60:              class="nav_icon"
61:              href="https://github.com/Decta2/"
62:              role="button">
63:              <i class="fab fa-github"></i
64:            ></a>
65:          </div>
66:        </div>
67:        <!-- Collapsible wrapper -->
68:      </div>
69:      <!-- Container wrapper -->
70:    </nav>
71:    <p style="color: green"><%= notice %></p>
72:    <header class="d-flex justify-content-center align-items-start">
73:        <div>
74:          <%= render @post %>
75:        </div>
76:    
77:        <div class="card m-3 p-3 card_">
78:          <div class="container">
79:            <%= render 'comments/form', post: @post %>
80:          </div>
81:    
82:          <div>
83:            <% @comments.each do |comment| %>
84:    
85:                <% if comment.post.id == @post.id %>
86:                  <div class="d-flex align-items-start container_theme">
87:                    <%= image_tag("user.png", class:"user_comment_png")%>
88:                    <div>
89:                    <p class="comment_email">
90:                      <%= comment.user.email %> <br>
91:                      <p class="comment_content"><%= comment.content %></p>
92:                    </p></div>
93:                  </div>
94:                <% end %>
95:    
96:            <% end %>
97:          </div>
98:          <div> 
99:          <% if current_user.id == @post.user_id %>
100:              <%= link_to "Edit this post", edit_post_path(@post) %><i class="fa-solid fa-pen-to-square m-1"></i> |
101:              <%= link_to "Back to posts", posts_path %><i class="fa-solid fa-arrow-right-from-bracket m-1"></i>
102:              <%= button_to "Destroy this post", @post, class:"btn btn-primary" method: :delete %>
103:          <% else %>
104:              <div class="back">
105:                <%= link_to "Back to posts", posts_path %> <i class="fa-solid fa-arrow-right-from-bracket m-1"></i>
106:              </div>
107:          <% end %>
108:      </div>
109:        </div>
110:    </header>
111:    </body>
  
