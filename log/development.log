      <ul style="margin-left:50px;" class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item m-3">
          <%= link_to "Dashboard", projects_path, style:"text-decoration:none; color:#97999b;"%>
        </li>
        <li class="nav-item d-flex align-items-center m-3">
              <%= link_to "New project", new_project_path, style:"text-decoration:none; color:#97999b;"%>
        </li>
      </ul>
      <!-- Left links -->

      <div class="d-flex align-items-center">
        <button type="button" >
        <% if current_user%>
               <% link_to "Log out", destroy_user_session_path, method: :delete class:"btn btn-primary btn-link px-3 me-2" %>
            <%else%>
                <% link_to "Login", new_user_session_path %>
        <% end %>
        </button>
        
        
        <a
          class="btn btn-dark px-3"
          href="https://github.com/Decta2/"
          role="button">
          <i class="fab fa-github"></i
        ></a>
      </div>
    </div>
    <!-- Collapsible wrapper -->
  </div>
  <!-- Container wrapper -->
</nav>

<p style="color: green"><%= notice %></p>

<h1 style="text-align:center;">Projects</h1>
<div id="projects" class="d-flex">
  
  <% @projects.each do |project| %>
<div class="d-flex justify-content-center">
  <div class="m-3 justify-content-center ">
  <% if project.user.id == current_user.id %>
  
  
    <%= render project %>
    <p class="d-flex justify-content-center mt-2">
      <%= link_to "Show this project", project, class:"btn btn-primary"%>
    </p>
    </div>
  <% end %>
 </div>
  <% end %>
